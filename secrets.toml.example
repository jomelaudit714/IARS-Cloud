# Server-side Supabase access for the PDF archive, auditor directory,
# and administrator-approved IARS user accounts.
[supabase]
url = "https://YOUR-PROJECT.supabase.co"
service_role_key = "YOUR-SERVICE-ROLE-KEY"
bucket = "audit-pdf-archive"
table = "pdf_archive"

# Exactly one IARS administrator account. Keep these values only in
# Streamlit Secrets; never commit real credentials to GitHub.
[iars_admin]
username = "jomel"
password = "REPLACE-WITH-A-STRONG-ADMIN-PASSWORD"
full_name = "Jomel Santiago"
code_secret = "REPLACE-WITH-A-LONG-RANDOM-SECRET"
session_timeout_minutes = 30
users_table = "iars_users"
log_table = "iars_auth_log"

[archive]
# Required to open the Saved PDFs tab.
access_pin = "CHANGE-THIS-ARCHIVE-PIN"
