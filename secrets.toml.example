# Supabase server-side access for archives, document libraries,
# auditor records, and administrator-approved IARS accounts.
[supabase]
url = "https://YOUR-PROJECT.supabase.co"
service_role_key = "YOUR-SERVICE-ROLE-KEY"

# Shared audit-report PDF archive
bucket = "audit-pdf-archive"
table = "pdf_archive"

# Report Templates and Policies & Memoranda libraries
# These values are optional because the code uses the same defaults.
documents_bucket = "iars-document-library"
documents_table = "document_library"

# Exactly one IARS administrator account. Keep actual values only in
# Streamlit Secrets. Never commit real credentials to GitHub.
[iars_admin]
username = "jomel"
password = "REPLACE-WITH-A-STRONG-ADMIN-PASSWORD"
full_name = "Jomel Santiago"
code_secret = "REPLACE-WITH-A-LONG-RANDOM-SECRET"
session_timeout_minutes = 30
users_table = "iars_users"
log_table = "iars_auth_log"
profile_table = "iars_profiles"
profile_bucket = "iars-profile-pictures"

[archive]
# Retained for backward compatibility. Signed-in users no longer need
# to enter a separate archive PIN.
access_pin = "OPTIONAL-LEGACY-PIN"
